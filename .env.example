# Copy this file to ".env" and fill in your real values.
# Never commit the real ".env" file to version control.

# Personal Access Token with "repo" scope (classic) or
# "Contents: Read" + "Pull requests: Read & Write" (fine-grained)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your Anthropic API key (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Claude model to use for reviews
ANTHROPIC_MODEL=claude-sonnet-4-5
